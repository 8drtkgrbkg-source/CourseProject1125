<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:CourseProject1125.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CourseProject1125.Views.AdminWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Title="AdminWindow">
    <Grid ColumnDefinitions="250, *">
        <Border Grid.Column="0" Background="DarkGray" Padding="10">
            <StackPanel Spacing="5">
                <TextBlock Text="БИБЛИОТЕКА" Foreground="White" FontSize="20"
                            FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    <Button Content="Книги" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Black"/>
                    <Button Content="Читатели" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Black"/>
                    <Button Content="Выдача книг" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Black"/>
                    <Button Content="Авторы" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Black"/>
                    <Button Content="Отчеты" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Black"/>
                        <Separator Margin="0,20" Background="Gray" />
        </StackPanel>
    </Border>
        
    <Button Content="Выход" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="Red" Command="{Binding FullExitCommand}"/>
    
        <Grid Grid.Column="1" RowDefinitions="Auto, *">
            <Border Grid.Row="0" Background="White" Height="50" Padding="15,0">
            </Border>
            <TextBlock Text="Список книг" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
            <DataGrid Grid.Row="1" Margin="10" AutoGenerateColumns="True" IsReadOnly="True" x:Name="MainDataGrid">
            </DataGrid>
        </Grid>
    </Grid>
</Window>
